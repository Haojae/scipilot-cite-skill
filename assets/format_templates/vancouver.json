{
  "style_name": "Vancouver",
  "in_text_format": "({number})",
  "multiple_citations": "({numbers_comma_separated})",
  "consecutive_citations": "({start}-{end})",
  "reference_entry": {
    "journal": "{number}. {authors_vancouver_style}. {title}. {journal_abbrev}. {year};{volume}({issue}):{pages}.",
    "conference": "{number}. {authors_vancouver_style}. {title}. In: {conference}. {year}. p. {pages}.",
    "book": "{number}. {authors_vancouver_style}. {title}. {publisher}; {year}."
  },
  "author_format": {
    "max_display": 6,
    "et_al_threshold": 7,
    "separator": ", ",
    "last_separator": ", ",
    "name_format": "last_initials_no_punct",
    "et_al_text": "et al"
  },
  "title_case": "sentence",
  "language": "en",
  "journal_abbreviation": true,
  "examples": [
    "1. Vaswani A, Shazeer N, Parmar N, Uszkoreit J, Jones L, Gomez AN, et al. Attention is all you need. Adv Neural Inf Process Syst. 2017;30:5998-6008.",
    "2. LeCun Y, Bengio Y, Hinton G. Deep learning. Nature. 2015;521(7553):436-44."
  ]
}
